{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read",
      "Edit",
      "Write",
      "Bash(cd *)",
      "Bash(ls *)",
      "Bash(pwd *)",
      "Bash(mkdir *)",
      "Bash(rmdir *)",    
      "Bash(git *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(head *)",
      "Bash(echo *)",
      "Bash(.venv/Scripts/python.exe *)",
      "Bash(python *)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  }
}
