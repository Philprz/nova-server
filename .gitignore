# Python
__pycache__/
*.py[cod]
*.pyd
*.pyo
*.pyc

# Artefacts de compilation Cython (Lot 5) - .c intermediaires (jamais committes)
*.c

# Environnements virtuels
venv/
.venv/
ENV/
env/
.Python

# Configuration sensible
.env
.env.local
.env.production
.env.*.local

# Coffre chiffre et cle maitre (Lot 1 - ne JAMAIS committer)
secrets.enc
*.enc
nova_vault.key
*.master.key

# Module de cle maitre embarquee (Lot 2/2b) : genere au build, JAMAIS commite ni
# livre en source. Seul _vault_key.pyd (compile) est embarque. *.py[cod] ci-dessus
# ne couvre PAS le .py, d'ou cette entree explicite.
_vault_key.py

# Bases de données locales
*.db
*.sqlite
*.sqlite3
api_cache.sqlite

# Logs
logs/
*.log

# Alembic migrations (spécifiques à chaque environnement)
alembic/versions/*.py
!alembic/versions/__init__.py

# Données clients et pièces jointes (RGPD)
data/attachments/
*.eml
# PDF interdits par défaut (souvent docs clients), autorisés uniquement dans docs/
*.pdf
!docs/**/*.pdf

# Binaires
*.exe

# Artefacts de tests
.coverage
htmlcov/
.pytest_cache/
.tox/

# IDE
.vscode/
.idea/
*.iml
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Nom réservé Windows (périphérique) - évite "error: invalid path 'nul'"
/nul
nul

# Build frontend
node_modules/
dist/
build/
/build/
/dist/

# Fichiers temporaires
tmp/
temp/
*.tmp
*.bak
*.backup

# Certificats et clés
*.pem
*.key
*.crt
*.apikey

# Diagnostics contenant des fragments de credentials
claude_diagnostic_results*.json

# Fichiers de configuration locale pour les scripts push
.ai_commit_initialized
.push_selector_initialized

# Claude Desktop config
claude_desktop_config.json

# Documentation générée
docs/_build/
docs/build/

# Heroku
.slugignore
.qodo
