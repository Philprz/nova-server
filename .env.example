# =============================================================================
# NOVA-SERVER — Modèle de configuration (.env.example)
# =============================================================================
# Copier ce fichier en `.env` et renseigner les VRAIES valeurs sur le serveur.
# Ce fichier d'exemple ne contient AUCUN secret réel — uniquement des
# placeholders. Le `.env` réel est gitignoré et ne doit jamais être commité.
#
# Convention : les variables marquées « REQUIS PROD » doivent impérativement
# être renseignées avant la mise en production RONDOT.
# =============================================================================

# -----------------------------------------------------------------------------
# Mode & serveur
# -----------------------------------------------------------------------------
NOVA_MODE=production            # REQUIS PROD — active logs INFO + cookies secure (HTTPS)
APP_PORT=8001                  # Port d'écoute NOVA (défaut 8001)
DISABLE_DOCS=true              # REQUIS PROD — désactive /docs /redoc /openapi.json
# NOTE : UVICORN_RELOAD n'est PAS lu par le code. uvicorn.run() est appelé sans
# reload= (main.py), donc le rechargement auto est TOUJOURS désactivé. La ligne
# ci-dessous est purement documentaire (laisser false).
UVICORN_RELOAD=false

# -----------------------------------------------------------------------------
# Base de données & cache
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/nova   # REQUIS PROD
REDIS_URL=redis://localhost:6379/0                            # REQUIS PROD (health check)

# -----------------------------------------------------------------------------
# Secrets d'authentification NOVA
# -----------------------------------------------------------------------------
# Générer : python -c "import secrets; print(secrets.token_hex(32))"  -> 64 hex
NOVA_JWT_SECRET=                # REQUIS PROD — hex 64 ; vide => émission de tokens impossible
NOVA_JWT_ACCESS_TTL_MINUTES=30
NOVA_JWT_REFRESH_TTL_DAYS=7
# Secret de signature des cookies de session SAP
COOKIE_SECRET=                  # REQUIS PROD — chaîne aléatoire longue
PA_COOKIE_NAME=nova_sap_session
SESSION_IDLE_MINUTES=30
SESSION_ABSOLUTE_MINUTES=480
# Chemin secret de la page admin + TTL session admin
NOVA_ADMIN_SECRET_PATH=
NOVA_ADMIN_SESSION_TTL=3600

# -----------------------------------------------------------------------------
# Fournisseurs LLM (routeur : Mistral principal, Anthropic fallback)
# AUCUNE clé OpenAI : OpenAI est retiré du déploiement RONDOT.
# -----------------------------------------------------------------------------
MISTRAL_API_KEY=                # REQUIS PROD — provider LLM principal
MISTRAL_MODEL=mistral-large-latest
ANTHROPIC_API_KEY=              # REQUIS PROD — provider LLM fallback
ANTHROPIC_MODEL=claude-sonnet-4-6

# -----------------------------------------------------------------------------
# SAP Business One — Service Layer (REST)
# -----------------------------------------------------------------------------
SAP_REST_BASE_URL=https://sap-host:50000/b1s/v1   # REQUIS PROD
SAP_USER=manager                                   # REQUIS PROD
SAP_CLIENT_PASSWORD=                               # REQUIS PROD
SAP_CLIENT=RON_20260109                            # REQUIS PROD — base société SAP
SAP_LANG=fr-FR
# Surcharges spécifiques RONDOT (utilisées en priorité si présentes)
SAP_USER_RONDOT=
SAP_CLIENT_RONDOT=
SAP_CLIENT_PASSWORD_RONDOT=
# Vérification TLS du certificat SAP : chemin vers le bundle CA.
# Si VIDE : la vérification TLS est DÉSACTIVÉE (un warning est loggué au
# démarrage, l'application ne plante pas). RENSEIGNER EN PROD.
SAP_CA_BUNDLE_PATH=/etc/ssl/certs/sap_ca_bundle.pem   # REQUIS PROD
# Accès SQL direct SAP (lecture historiques / produits)
SAP_SQL_SERVER=
SAP_SQL_DATABASE=
SAP_SQL_USER=
SAP_SQL_PASSWORD=
# Moteur de prix externe (si déployé séparément)
PRICE_ENGINE_URL=

# -----------------------------------------------------------------------------
# Microsoft Graph (mailbox mail-to-biz) & Webhook
# -----------------------------------------------------------------------------
MS_TENANT_ID=                   # REQUIS PROD
MS_CLIENT_ID=                   # REQUIS PROD
MS_CLIENT_SECRET=               # REQUIS PROD
MS_MAILBOX_ADDRESS=             # REQUIS PROD — boîte surveillée
GRAPH_USER_ID=
WEBHOOK_NOTIFICATION_URL=https://nova-host/api/graph/webhook
# Secret de validation des notifications webhook Graph (>= 32 caractères).
# Générer : python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_CLIENT_STATE=           # REQUIS PROD — >= 32 caractères

# -----------------------------------------------------------------------------
# Enrichissement client (INSEE / base locale ; Pappers DÉSACTIVÉ par défaut)
# -----------------------------------------------------------------------------
# Sources actives. Défaut sans Pappers (API payante, hors budget RONDOT).
# Pour réactiver Pappers : "insee,local,pappers" + renseigner PAPPERS_API_KEY.
CLIENT_ENRICHMENT_SOURCES=insee,local
INSEE_API_KEY=
INSEE_CONSUMER_KEY=
INSEE_CONSUMER_SECRET=
# Pappers : laisser VIDE en prod RONDOT (aucun appel déclenché si vide).
PAPPERS_API_KEY=
PAPPERS_URL=https://api.pappers.fr/v2

# -----------------------------------------------------------------------------
# Salesforce (via MCP)
# -----------------------------------------------------------------------------
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=
SALESFORCE_DOMAIN=login

# -----------------------------------------------------------------------------
# Quota mensuel de devis (blocage dur RONDOT)
# -----------------------------------------------------------------------------
QUOTA_SOCIETY_ID=rondot
QUOTA_DEVIS_MAX=50

# -----------------------------------------------------------------------------
# Transport / DHL Express (optionnel — calcul des frais de port)
# -----------------------------------------------------------------------------
DHL_USERNAME=
DHL_PASSWORD=
DHL_ACCOUNT_NUMBER=
DHL_SHIPPER_POSTAL=
DHL_SHIPPER_CITY=
DHL_SHIPPER_COUNTRY=FR
DHL_USE_TEST_ENV=false

# -----------------------------------------------------------------------------
# Moteur de pricing & validation (valeurs par défaut raisonnables dans le code)
# -----------------------------------------------------------------------------
PRICING_ENGINE_ENABLED=true
PRICING_DEFAULT_MARGIN=45.0
PRICING_MIN_MARGIN=
PRICING_MAX_MARGIN=
USE_SAP_PRICING_FUNCTION=false
PRICING_BASE_CURRENCY=EUR
CURRENCY_CACHE_HOURS=24

# -----------------------------------------------------------------------------
# Debug (laisser désactivé en production)
# -----------------------------------------------------------------------------
# Expose le payload SAP brut dans les réponses /api/sap/quotation* (debug only).
EXPOSE_SAP_PAYLOAD=false
