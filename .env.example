# ============================================
# NOVA-SERVER - Exemple de configuration .env
# Copier ce fichier en `.env` et renseigner les valeurs réelles.
# Aucune valeur sensible ne doit être commitée dans ce fichier.
# ============================================

# ====
# Configuration application
# ====
APP_HOST=0.0.0.0
APP_PORT=8001
UVICORN_RELOAD=false
LOG_LEVEL=info

# ====
# Clés API LLM
# ====
# LLM principal : Mistral (compatible OpenAI). Endpoint : https://api.mistral.ai/v1
MISTRAL_API_KEY=your-mistral-api-key-here
MISTRAL_MODEL=mistral-large-latest
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-proj-...
# CLAUDE_DESKTOP_PATH=C:\chemin\vers\claude.exe

ABACUS_API_KEY=s2_...

OPENAI_MODEL=gpt-4.1
ANTHROPIC_MODEL=claude-sonnet-4-6

# ====
# Salesforce
# ====
SALESFORCE_USERNAME=votre_utilisateur@agentforce.com
SALESFORCE_PASSWORD=votre_mot_de_passe_salesforce
SALESFORCE_SECURITY_TOKEN=votre_token_securite
SALESFORCE_DOMAIN=orgfarm-xxxxxxxxx-dev-ed.develop.my.salesforce.com
SALESFORCE_URL=https://orgfarm-xxxxxxxxx-dev-ed.develop.my.salesforce.com

SALESFORCE_CONSUMER_KEY=votre_consumer_key_connected_app
SALESFORCE_CONSUMER_SECRET=votre_consumer_secret_connected_app

# ====
# SAP Business One (REST)
# ====
SAP_ASHOST=https://votre-host-sap:50000
SAP_LANG=FR
SAP_REST_BASE_URL=https://votre-host-sap:50000/b1s/v1

SAP_USER=votre_user_sap
SAP_CLIENT=SBODemoFR
SAP_CLIENT_PASSWORD=votre_password_sap
PRICE_ENGINE_URL=https://votre-host-sap:50000/b1s/v1/CompanyService_GetItemPrice
PRICE_ENGINE_LOGIN_URL=https://votre-host-sap:50000/b1s/v1/Login

# Chemin vers le bundle CA pour vérifier le certificat SAP en HTTPS.
# Si vide ou non défini, la vérification TLS est DÉSACTIVÉE (WARNING au démarrage).
# Exemple : SAP_CA_BUNDLE_PATH=C:\certs\sap_ca_bundle.pem
SAP_CA_BUNDLE_PATH=

# ====
# Configuration SAP RONDOT
# ====
SAP_USER_RONDOT=votre_user_sap_rondot
SAP_CLIENT_RONDOT=RON_AAAAMMJJ
SAP_CLIENT_PASSWORD_RONDOT=votre_password_sap_rondot

# Configuration SQL Server direct (pour fonctions SQL SAP personnalisées)
SAP_SQL_SERVER=votre.host.sap
SAP_SQL_DATABASE=RON_AAAAMMJJ
SAP_SQL_USER=votre_user_sql
SAP_SQL_PASSWORD=votre_password_sql
USE_SAP_PRICING_FUNCTION=true

# ====
# Configuration Microsoft Graph (Azure AD)
# ====
MS_TENANT_ID=00000000-0000-0000-0000-000000000000
MS_CLIENT_ID=00000000-0000-0000-0000-000000000000
MS_CLIENT_SECRET=votre_client_secret_azure_ad
MS_MAILBOX_ADDRESS=mailbox@votre-domaine.fr

# ====
# Bases de données
# ====
DATABASE_URL=postgresql://user:password@localhost:5432/nova_mcp

# ====
# Configuration WebSocket
# ====
WEBSOCKET_ENABLED=true
WEBSOCKET_TIMEOUT=300
# Timeout pour les connexions WebSocket en secondes

# ====
# Configuration validation
# ====
USER_VALIDATION_ENABLED=true
AUTO_SUGGEST_THRESHOLD=0.8
MAX_ALTERNATIVES=5
# Nombre maximum d'alternatives pour les suggestions automatiques

# ====
# API Keys pour enrichissement
# ====
INSEE_API_KEY=votre_cle_insee
PAPPERS_API_KEY=votre_cle_pappers

INSEE_CONSUMER_KEY=votre_cle_insee
INSEE_CONSUMER_SECRET=Search_Societe

PAPPERS_API=votre_cle_pappers
PAPPERS_URL=https://api.pappers.fr/v2/

# Configuration de l'agent de recherche
COMPANY_SEARCH_ENABLED=true
COMPANY_SEARCH_CACHE_TTL=3600  # Cache TTL en secondes (1 heure)
COMPANY_SEARCH_MAX_RESULTS=20  # Nombre maximum de résultats par recherche
COMPANY_SEARCH_TIMEOUT=10      # Timeout des requêtes API en secondes

# Configuration enrichissement client
CLIENT_ENRICHMENT_ENABLED=true
CLIENT_ENRICHMENT_AUTO=true    # Enrichissement automatique des clients
CLIENT_ENRICHMENT_SOURCES=insee,pappers,local  # Sources d'enrichissement

# Configuration API rate limiting
INSEE_API_RATE_LIMIT=100       # Requêtes par heure
PAPPERS_API_RATE_LIMIT=1000    # Requêtes par heure

# Configuration base de données locale
LOCAL_COMPANIES_DB_ENABLED=true
LOCAL_COMPANIES_DB_UPDATE_INTERVAL=86400  # Mise à jour quotidienne (24h)

# Configuration logging spécifique
COMPANY_SEARCH_LOG_LEVEL=INFO
COMPANY_SEARCH_LOG_FILE=logs/company_search.log

# Configuration export
EXPORT_DIRECTORY=exports/companies
EXPORT_FORMATS=json,csv

# ====
# Redis & Mode applicatif
# ====
REDIS_URL=redis://localhost:6379

NOVA_MODE=production
SUPPLIER_TARIFF_FOLDER='C:\chemin\vers\tarifs_fournisseurs'

# ====
# Configuration Pricing Engine Intelligent (Phase 3)
# ====
PRICING_ENGINE_ENABLED=true
PRICING_DEFAULT_MARGIN=40.0
PRICING_MIN_MARGIN=35.0
PRICING_MAX_MARGIN=45.0
PRICING_STABILITY_THRESHOLD=5.0
PRICING_LOOKBACK_DAYS=365
PRICING_MIN_REFERENCE_SALES=3
PRICING_REQUIRE_VALIDATION_CAS_2=true
PRICING_REQUIRE_VALIDATION_CAS_4=true
PRICING_CREATE_VALIDATIONS=true
PRICING_BASE_CURRENCY=EUR

# ====
# Configuration SAP History Service
# ====
SAP_HISTORY_MAX_RESULTS=50
SAP_HISTORY_CACHE_TTL=3600

# ====
# Configuration Workflow Validation (Phase 4)
# ====
VALIDATION_AUTO_APPROVE_THRESHOLD=3.0
VALIDATION_AUTO_REJECT_THRESHOLD=50.0
VALIDATION_EXPIRATION_HOURS=48
VALIDATION_URGENT_EXPIRATION_HOURS=4
VALIDATION_NOTIFY_ON_CREATION=true
VALIDATION_EMAIL=validation@votre-domaine.fr
VALIDATION_HIGH_PRIORITY_THRESHOLD=10.0
VALIDATION_URGENT_PRIORITY_THRESHOLD=20.0
VALIDATION_DEFAULT_VALIDATORS=

# ====
# Configuration Currency Service
# ====
CURRENCY_CACHE_HOURS=4

# ====
# Pricing filiales UK (F0014 HEYE INTERNATIONAL GmbH, F0018 SHEPPEE)
# Formule : PA (£) × GBP_EUR_RATE × DISCOUNT_RATE / MARGIN_DIVISOR
# ====
UK_SUPPLIER_GBP_EUR_RATE=1.20
UK_SUPPLIER_DISCOUNT_RATE=0.75
UK_SUPPLIER_MARGIN_DIVISOR=0.60

# ====
# Configuration Transport
# ====
TRANSPORT_DEFAULT_CARRIER=chronopost
TRANSPORT_API_ENABLED=false

# ============================================
# WEBHOOK MICROSOFT GRAPH (Traitement automatique)
# ============================================
WEBHOOK_NOTIFICATION_URL=https://votre-domaine.fr/api/webhooks/notification
# Secret partagé Microsoft Graph ↔ NOVA : valeur aléatoire >= 32 caractères.
# Si absent ou vide, le serveur lèvera un RuntimeError au démarrage (P4-C11).
# Générer p.ex. : python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_CLIENT_STATE=remplacer_par_un_secret_aleatoire_de_32_caracteres_minimum

GRAPH_USER_ID=00000000-0000-0000-0000-000000000000

# ── NOVA Auth ──────────────────────────────────────────
# Générer p.ex. : python -c "import secrets; print(secrets.token_hex(32))"
NOVA_JWT_SECRET=remplacer_par_secret_hex_64_caracteres
NOVA_JWT_ACCESS_TTL_MINUTES=60
NOVA_JWT_REFRESH_TTL_DAYS=7

# Sécurité : désactiver la doc OpenAPI publique en production
DISABLE_DOCS=true
